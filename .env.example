# Solana testnet — Ledger A
WALLET_A_PUBLIC=
WALLET_A_SECRET=

# Solana testnet — Ledger B
WALLET_B_PUBLIC=
WALLET_B_SECRET=

# Solana RPC (defaults to testnet)
SOLANA_RPC_URL=https://api.testnet.solana.com

# ── Hardware mode ────────────────────────────────────────────────────────────
# Set to true once both Arduinos are flashed with v4 firmware and plugged in.
# When true: requires Arduino connection + PIN entry for all transactions.
# When false: software-only mode (no hardware needed).
# NEXT_PUBLIC_ prefix makes it available in the browser.
NEXT_PUBLIC_HARDWARE_MODE=true

# Auth0 (Regular Web Application) — https://manage.auth0.com
# Callback: {APP_BASE_URL}/auth/callback  |  Logout URL: {APP_BASE_URL}
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_SECRET=
APP_BASE_URL=http://localhost:3000

# ── Ledger activity logs (MongoDB Atlas or local) ─────────────────────────────
# Use either variable name (same connection string).
MONGODB_URI=
MONGODB_DB_NAME=cryptx

# Ledger log batch flush delay (ms). Random delay in [min, max] per cycle (default 30 s).
LEDGER_LOG_FLUSH_MIN_MS=30000
LEDGER_LOG_FLUSH_MAX_MS=30000

# ── AI Insights (Gemini) ─────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
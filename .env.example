# Solana testnet — Ledger A
WALLET_A_PUBLIC=
WALLET_A_SECRET=

# Solana testnet — Ledger B
WALLET_B_PUBLIC=
WALLET_B_SECRET=

# Solana RPC (defaults to testnet)
SOLANA_RPC_URL=https://api.testnet.solana.com

# ── Hardware mode ────────────────────────────────────────────────────────────
# Set to true once both Arduinos are flashed with v4 firmware and plugged in.
# When true: requires Arduino connection + PIN entry for all transactions.
# When false: software-only mode (no hardware needed).
# NEXT_PUBLIC_ prefix makes it available in the browser.
NEXT_PUBLIC_HARDWARE_MODE=true

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=